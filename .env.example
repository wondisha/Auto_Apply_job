# Primary Gemini model
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Candidate assets
RESUME_PATH=wondi.pdf
# TARGET_JOB_URL=https://www.linkedin.com/jobs/view/1234567890/

# Browser settings
# BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
BROWSER_HEADLESS=true

# Fallback model settings
FALLBACK_LLM_PROVIDER=ollama
FALLBACK_LLM_MODEL=qwen2.5:3b
OLLAMA_HOST=http://localhost:11434

# Verified application policy
REQUIRE_VERIFIED_COMPANY=1
DAILY_APPLICATION_TARGET=5
VERIFIED_COMPANY_ALLOWLIST=
PREFERRED_ROLE_KEYWORDS=snowflake,data engineer,database administrator,data platform,cloud data operations,sql server
PREFERRED_LOCATION_KEYWORDS=Garland,Texas,Dallas,Remote,Hybrid

# Local document-generation controls
DOCUMENT_LLM_MODEL=qwen2.5:3b
DOCUMENT_RESUME_CHAR_LIMIT=3500
DOCUMENT_JOB_CHAR_LIMIT=2000
DOCUMENT_MAX_TOKENS=450

# Retry behavior
AGENT_MAX_RETRIES=3
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_DELAY=2
GEMINI_RETRY_MAX_DELAY=30
